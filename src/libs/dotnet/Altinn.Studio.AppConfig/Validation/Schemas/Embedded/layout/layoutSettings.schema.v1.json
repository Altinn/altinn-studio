{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://altinncdn.no/schemas/json/layout/layoutSettings.schema.v1.json",
  "title": "Altinn layout settings",
  "description": "Schema that describes settings for the layout configuration for Altinn applications.",
  "$ref": "#/definitions/ILayoutSettings",
  "definitions": {
    "AllowedValidationMasks": {
      "title": "Validation types",
      "description": "List of validation types to show",
      "type": "array",
      "items": {
        "enum": [
          "Schema",
          "Component",
          "Expression",
          "CustomBackend",
          "Required",
          "AllExceptRequired",
          "All"
        ]
      }
    },
    "GlobalPageSettingsFromSchema": {
      "title": "GlobalPageSettingsFromSchema",
      "type": "object",
      "properties": {
        "hideCloseButton": {
          "title": "Hide close button",
          "description": "Hide the close button in the upper right corner of the app",
          "default": false,
          "type": "boolean"
        },
        "showLanguageSelector": {
          "title": "Show language selector",
          "description": "Show the language selector in the upper right corner of the app",
          "default": false,
          "type": "boolean"
        },
        "showExpandWidthButton": {
          "title": "Show expand width button",
          "description": "Show the expand width button in the upper right corner of the app",
          "default": false,
          "type": "boolean"
        },
        "expandedWidth": {
          "title": "Expanded width",
          "description": "Sets expanded width for pages",
          "default": false,
          "type": "boolean"
        },
        "showProgress": {
          "title": "Show progress indicator",
          "description": "Enables a progress indicator in the upper right corner of the app (when on data tasks/forms)",
          "default": false,
          "type": "boolean"
        },
        "autoSaveBehavior": {
          "title": "Auto save behavior",
          "description": "An attribute specifying when the application will save form data. onChangeFormData saves on every interaction with form elements. onChangePage saves on every page change.",
          "default": "onChangeFormData",
          "enum": [
            "onChangeFormData",
            "onChangePage"
          ]
        },
        "navigationTitle": {
          "title": "Navigation title",
          "description": "Overrides the default \"Skjemasider\" heading shown in the navigation panel. Can be a text resource key or a dynamic expression that reads from the data model.",
          "$ref": "expression.schema.v1.json#/definitions/string"
        },
        "taskNavigation": {
          "title": "Task navigation settings",
          "description": "Shows the listed tasks in the sidebar navigation menu",
          "default": [],
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/definitions/NavigationTaskFromSchema"
              },
              {
                "$ref": "#/definitions/NavigationReceiptFromSchema"
              }
            ]
          }
        },
        "validationOnNavigation": {
          "$ref": "#/definitions/PageValidation"
        }
      }
    },
    "IComponentsSettings": {
      "title": "IComponentsSettings",
      "type": "object",
      "properties": {
        "excludeFromPdf": {
          "title": "Exclude from PDF",
          "description": "List of components to exclude from the PDF generation",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "excludeFromPdf"
      ],
      "additionalProperties": false
    },
    "ILayoutSettings": {
      "title": "Layout settings",
      "description": "Settings regarding layout pages and components",
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "pages": {
          "$ref": "#/definitions/IPagesSettings"
        },
        "components": {
          "$ref": "#/definitions/IComponentsSettings"
        },
        "defaultDataType": {
          "title": "Default data model",
          "description": "The default data model type to be used for bindings not specifying a dataType in these layouts",
          "type": "string"
        }
      },
      "required": [
        "pages"
      ],
      "additionalProperties": false
    },
    "INavigationBasePageGroup": {
      "title": "INavigationBasePageGroup",
      "type": "object",
      "properties": {
        "type": {
          "default": "default",
          "enum": [
            "default",
            "info"
          ]
        },
        "markWhenCompleted": {
          "description": "Whether this group should mark pages as completed when the user finishes",
          "default": false,
          "type": "boolean"
        },
        "expandedByDefault": {
          "description": "Whether the sidebar group should be expanded by default",
          "default": false,
          "type": "boolean"
        }
      }
    },
    "IPagesBaseSettings": {
      "title": "IPagesBaseSettings",
      "type": "object",
      "properties": {
        "excludeFromPdf": {
          "title": "Exclude from PDF",
          "description": "List of pages to exclude from the PDF generation",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pdfLayoutName": {
          "title": "PDF layout name",
          "description": "Name of a custom layout file to use for PDF creation instead of the automatically generated PDF.",
          "type": "string"
        },
        "validationOnNavigation": {
          "$ref": "#/definitions/PageValidation"
        }
      }
    },
    "IPagesSettings": {
      "title": "IPagesSettings",
      "oneOf": [
        {
          "$ref": "#/definitions/IPagesSettingsWithOrder"
        },
        {
          "$ref": "#/definitions/IPagesSettingsWithGroups"
        }
      ]
    },
    "IPagesSettingsWithGroups": {
      "allOf": [
        {
          "$ref": "#/definitions/GlobalPageSettingsFromSchema"
        },
        {
          "$ref": "#/definitions/IPagesBaseSettings"
        },
        {
          "title": "IPagesSettingsWithGroups",
          "type": "object",
          "properties": {
            "groups": {
              "title": "Page groups",
              "description": "List of page groups in the order they should appear in the application",
              "type": "array",
              "items": {
                "$ref": "#/definitions/NavigationPageGroup"
              }
            }
          },
          "required": [
            "groups"
          ]
        },
        {
          "type": "object",
          "properties": {
            "hideCloseButton": true,
            "showLanguageSelector": true,
            "showExpandWidthButton": true,
            "expandedWidth": true,
            "showProgress": true,
            "autoSaveBehavior": true,
            "navigationTitle": true,
            "taskNavigation": true,
            "validationOnNavigation": true,
            "excludeFromPdf": true,
            "pdfLayoutName": true,
            "groups": true
          },
          "required": [
            "groups"
          ],
          "additionalProperties": false
        }
      ]
    },
    "IPagesSettingsWithOrder": {
      "allOf": [
        {
          "$ref": "#/definitions/GlobalPageSettingsFromSchema"
        },
        {
          "$ref": "#/definitions/IPagesBaseSettings"
        },
        {
          "title": "IPagesSettingsWithOrder",
          "type": "object",
          "properties": {
            "order": {
              "title": "Page order",
              "description": "List of pages in the order they should appear in the application",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "order"
          ]
        },
        {
          "type": "object",
          "properties": {
            "hideCloseButton": true,
            "showLanguageSelector": true,
            "showExpandWidthButton": true,
            "expandedWidth": true,
            "showProgress": true,
            "autoSaveBehavior": true,
            "navigationTitle": true,
            "taskNavigation": true,
            "validationOnNavigation": true,
            "excludeFromPdf": true,
            "pdfLayoutName": true,
            "order": true
          },
          "required": [
            "order"
          ],
          "additionalProperties": false
        }
      ]
    },
    "NavigationPageGroup": {
      "title": "NavigationPageGroup",
      "oneOf": [
        {
          "$ref": "#/definitions/NavigationPageGroupMultiple"
        },
        {
          "$ref": "#/definitions/NavigationPageGroupSingle"
        }
      ]
    },
    "NavigationPageGroupMultiple": {
      "allOf": [
        {
          "$ref": "#/definitions/INavigationBasePageGroup"
        },
        {
          "title": "NavigationPageGroupMultiple",
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "order": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2
            }
          },
          "required": [
            "name",
            "order"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": true,
            "markWhenCompleted": true,
            "expandedByDefault": true,
            "name": true,
            "order": true
          },
          "required": [
            "name",
            "order"
          ],
          "additionalProperties": false
        }
      ]
    },
    "NavigationPageGroupSingle": {
      "allOf": [
        {
          "$ref": "#/definitions/INavigationBasePageGroup"
        },
        {
          "title": "NavigationPageGroupSingle",
          "type": "object",
          "properties": {
            "order": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "maxItems": 1
            }
          },
          "required": [
            "order"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": true,
            "markWhenCompleted": true,
            "expandedByDefault": true,
            "order": true
          },
          "required": [
            "order"
          ],
          "additionalProperties": false
        }
      ]
    },
    "NavigationReceiptFromSchema": {
      "title": "NavigationReceiptFromSchema",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "const": "receipt"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "NavigationTaskFromSchema": {
      "title": "NavigationTaskFromSchema",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        }
      },
      "required": [
        "taskId"
      ],
      "additionalProperties": false
    },
    "PageValidation": {
      "title": "PageValidation",
      "type": "object",
      "properties": {
        "page": {
          "title": "Page",
          "description": "Which pages should be validated when the next button is clicked.",
          "enum": [
            "current",
            "currentAndPrevious",
            "all"
          ]
        },
        "show": {
          "$ref": "#/definitions/AllowedValidationMasks"
        }
      },
      "required": [
        "page",
        "show"
      ],
      "additionalProperties": false
    }
  }
}

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Altinn.Studio.AppConfig</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <DebugType>portable</DebugType>
    <Description>
      Altinn Studio Application configuration parser and validation library.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="JsonSchema.Net" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Altinn.Studio.AppConfig.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Documents/Text/builtin-text-keys.json" LogicalName="builtin-text-keys.json" />
  </ItemGroup>
</Project>

FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine@sha256:5c559aa5d99337e400d39ab4fa1f6979d126c29b20939d53658ed38300571e74 AS build
WORKDIR /app

COPY src/Altinn.Augmenter.Agent/Altinn.Augmenter.Agent.csproj src/Altinn.Augmenter.Agent/
RUN dotnet restore src/Altinn.Augmenter.Agent/Altinn.Augmenter.Agent.csproj

COPY src/ src/
RUN dotnet publish src/Altinn.Augmenter.Agent/Altinn.Augmenter.Agent.csproj -c Release -o /out --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0-alpine@sha256:1e37a8236c558ae31bd6bc8144e38e6036b73cf1b0616fe56d79e60babb9d93b AS runtime
WORKDIR /app

# Typst (PDF) and Pandoc (DOCX). Agent calls go to a remote OpenAI-compatible
# gateway directly over HTTP — no Pi/npm/node in the image.
RUN apk add --no-cache --repository=https://dl-cdn.alpinelinux.org/alpine/edge/community typst \
    && apk add --no-cache pandoc

RUN addgroup -S appgroup && adduser -S -h /home/appuser appuser -G appgroup \
    && mkdir -p /etc/augmenter/templates /etc/augmenter/registries /etc/augmenter/rules /etc/augmenter/orchestrator /etc/augmenter/tools /etc/augmenter/mappings \
    && chown -R appuser:appgroup /etc/augmenter /home/appuser
ENV HOME=/home/appuser
USER appuser

COPY --from=build /out .

ENV ASPNETCORE_URLS=http://+:8072
EXPOSE 8072

ENTRYPOINT ["dotnet", "Altinn.Augmenter.Agent.dll"]

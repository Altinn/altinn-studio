{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Callback": {
    "AllowedPatterns": [],
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "RetryBaseDelaySeconds": 2
  },
  "Upload": {
    "MaxFileBytes": 10485760,
    "MaxTotalBytes": 52428800
  },
  "PdfGeneration": {
    "ProcessTimeoutSeconds": 60
  },
  "ContentPaths": {
    "TemplatesRoot": "/etc/augmenter/templates",
    "RegistriesRoot": "/etc/augmenter/registries",
    "RulesRoot": "/etc/augmenter/rules",
    "OrchestratorRoot": "/etc/augmenter/orchestrator",
    "ToolsRoot": "/etc/augmenter/tools",
    "MappingsRoot": "/etc/augmenter/mappings"
  }
}

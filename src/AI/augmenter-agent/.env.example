# Copy to .env (gitignored) and fill in real values.
# docker-compose forwards EVERY variable in this file into the container.
#
# Two layers of config:
#   1) THIS file holds secrets (API keys) and chooses which model to call.
#   2) config/pi/models.json holds endpoint definitions for non-built-in providers
#      (Ollama, LM Studio, vLLM, proxies). It can reference env vars from here by name.
#
# Pi's built-in providers (anthropic, openai, google, groq, ...) do NOT need
# an entry in models.json — env vars below are enough.

# ── Always set ──────────────────────────────────────────────────────────────
Agent__Provider=pi
# Format: <provider-key>/<model-id>
#   built-in:        openai/gpt-4o-mini, google/gemini-2.5-pro, ...
#   custom (from models.json): lmstudio/qwen2.5-coder:7b, ollama/llama3.1:8b
Agent__Model=lmstudio/qwen2.5-coder:7b


# ── Pick the matching block; delete the rest ────────────────────────────────

# LM Studio (local, OpenAI-compatible) — entry "lmstudio" in models.json
LMSTUDIO_API_KEY=lmstudio
# Endpoint is in config/pi/models.json (baseUrl). Edit there if not :1234.

# Ollama (local) — entry "ollama" in models.json
# OLLAMA_API_KEY=ollama

# OpenAI (built-in provider)
# OPENAI_API_KEY=sk-...

# Google Gemini (built-in provider)
# GEMINI_API_KEY=...

# Groq (built-in provider)
# GROQ_API_KEY=gsk_...

# Anthropic (built-in provider — but if this is what you want, claude-cli locally is simpler)
# ANTHROPIC_API_KEY=sk-ant-...

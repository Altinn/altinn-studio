# Copy to .env (gitignored) and fill in real values.
# docker-compose forwards every variable in this file into the container.
#
# The production agent is sandkasse-http: a direct HTTP client to an
# OpenAI-compatible chat-completions gateway. For local development you can
# instead use the Claude CLI (Agent:Provider=claude-cli in
# appsettings.Development.json).

# ── Required for sandkasse-http ─────────────────────────────────────────────
# API key — mapped to Agent__ApiKey by docker-compose.yaml.
SANDKASSE_API_KEY=<your-sandkasse-api-key>

# ── Optional overrides ──────────────────────────────────────────────────────
# All have defaults in docker-compose.yaml; uncomment to override.
# Agent__Provider=sandkasse-http
# Agent__BaseUrl=https://gw.sandkasse.ai/v1
# Agent__Model=telenor:gemma4
# Agent__MaxTokens=4096
# Agent__Temperature=0
# Agent__TimeoutSeconds=300

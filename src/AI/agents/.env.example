# Altinity Agent Configuration
# Copy to .env.docker (Docker) or .env (local)

# =============================================================================
# REQUIRED: Digdir Gateway (OpenAI-compatible)
# =============================================================================
GATEWAY_API_KEY=your_gateway_api_key
# GATEWAY_BASE_URL=https://gw.sandkasse.ai/v1  # Optional - default set in base_config.py

# =============================================================================
# OPTIONAL: Gitea proxy (for cloning and pushing branches)
# =============================================================================
# GITEA_BASE_URL=http://host.docker.internal/repos  # Local: http://studio.localhost/repos

# =============================================================================
# Optional: MCP Server
# =============================================================================
# MCP_SERVER_URL=http://host.docker.internal:8070/sse # Local: http://localhost:8070/sse

# =============================================================================
# OPTIONAL: Per-role model overrides (all default to telenor:gemma4)
# =============================================================================
# LLM_MODEL_PLANNER=telenor:gemma4   # Complex reasoning
# LLM_MODEL_ACTOR=telenor:gemma4     # Code generation
# LLM_MODEL_REVIEWER=telenor:gemma4  # Code review
# LLM_MODEL_VERIFIER=telenor:gemma4  # Validation
# LLM_MODEL_ASSISTANT=telenor:gemma4 # Q&A chat

# =============================================================================
# OPTIONAL: Fallback OpenAI (if gateway not configured)
# =============================================================================
# OPENAI_API_KEY=your_openai_api_key

# =============================================================================
# REQUIRED: Langfuse Observability
# =============================================================================
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
LANGFUSE_RELEASE=altinity-agents-v1
LANGFUSE_ENVIRONMENT=local-dev  # development, staging, production

# =============================================================================
# OPTIONAL: Server & Logging
# =============================================================================
# API_HOST=0.0.0.0
# API_PORT=8071
# LOG_LEVEL=INFO
# DEBUG=false
# ENVIRONMENT=development

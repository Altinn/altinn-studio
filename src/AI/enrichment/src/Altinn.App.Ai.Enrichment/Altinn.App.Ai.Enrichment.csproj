<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Description>AI enrichment (KI Beriking) for Altinn apps: per-item LLM evaluation with deterministic tools, configured from the app's App/agents folder, exposed as the kiBeriking process service task.</Description>
    <PackageId>Altinn.App.Ai.Enrichment</PackageId>
    <Version>0.5.0-preview.4</Version>
    <Authors>Digdir AI-lab</Authors>
    <RepositoryUrl>https://github.com/Altinn/altinn-studio</RepositoryUrl>
    <PackageLicenseExpression>BSD-3-Clause</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Altinn.App.Core" Version="8.12.7" />
    <PackageReference Include="YamlDotNet" Version="16.*" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Altinn.App.Ai.Enrichment.Tests" />
  </ItemGroup>

</Project>

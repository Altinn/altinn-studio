<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Altinn.Studio.AppManager</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>app-manager</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../../Shared/AppTunnel/**/*.cs" LinkBase="AppTunnel" />
    <Compile Remove="Studioctl/Upgrade/**/*.cs" />
    <Compile Remove="Studioctl/Version/**/*.cs" />
  </ItemGroup>
</Project>

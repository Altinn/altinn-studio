{
  "include": ["*.ts"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@app/form-component/*": ["../../../../app-libs/form-component/src/*"],
      "@app/language/*": ["../../../../app-libs/language/src/*"],
      "src/*": ["../src/*"]
    }
  }
}

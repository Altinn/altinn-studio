{
  "name": "Lookup an entire repeating group",
  "expression": ["component", "personer"],
  "expects": [
    {
      "navn": "Ola",
      "alderIAar": 40
    },
    {
      "navn": "Kari",
      "alderIAar": 35
    },
    {
      "navn": "Knut",
      "alderIAar": 17
    }
  ],
  "layouts": {
    "Page1": {
      "$schema": "https://altinncdn.no/schemas/json/layout/layout.schema.v1.json",
      "data": {
        "layout": [
          {
            "id": "personer",
            "type": "RepeatingGroup",
            "dataModelBindings": {
              "group": "mennesker"
            },
            "children": ["navn", "alder"]
          },
          {
            "id": "navn",
            "type": "Input",
            "dataModelBindings": {
              "simpleBinding": "mennesker.navn"
            }
          },
          {
            "id": "alder",
            "type": "Input",
            "dataModelBindings": {
              "simpleBinding": "mennesker.alderIAar"
            }
          }
        ]
      }
    }
  },
  "dataModel": {
    "mennesker": [
      {
        "navn": "Ola",
        "alderIAar": 40
      },
      {
        "navn": "Kari",
        "alderIAar": 35
      },
      {
        "navn": "Knut",
        "alderIAar": 17
      }
    ]
  }
}

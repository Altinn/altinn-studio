{
  "name": "Lookup an object based on a component with several data model bindings",
  "layouts": {
    "Page1": {
      "$schema": "https://altinncdn.no/schemas/json/layout/layout.schema.v1.json",
      "data": {
        "layout": [
          {
            "id": "some-component",
            "type": "Address",
            "dataModelBindings": {
              "address": "address.street",
              "houseNumber": "address.houseNumber",
              "zipCode": "address.zipCode",
              "postPlace": "address.postPlace"
            }
          }
        ]
      }
    }
  },
  "dataModel": {
    "address": {
      "street": "Askedalen",
      "houseNumber": "4",
      "zipCode": "6863",
      "postPlace": "Leikanger"
    }
  },
  "expression": ["component", "some-component"],
  "expects": {
    "address": "Askedalen",
    "houseNumber": "4",
    "zipCode": "6863",
    "postPlace": "Leikanger"
  }
}

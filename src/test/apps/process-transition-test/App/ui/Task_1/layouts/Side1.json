{
  "$schema": "https://altinncdn.no/toolkits/altinn-app-frontend/4/schemas/json/layout/layout.schema.v1.json",
  "data": {
    "hidden": false,
    "layout": [
      {
        "size": "L",
        "id": "Task1Header",
        "type": "Header",
        "textResourceBindings": {
          "title": "Task1.header.title"
        }
      },
      {
        "id": "Task1Description",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Task1.description"
        }
      },
      {
        "dataModelBindings": {
          "simpleBinding": {
            "field": "phase",
            "dataType": "TransitionControl"
          }
        },
        "id": "phase",
        "type": "RadioButtons",
        "preselectedOptionIndex": 0,
        "options": [
          {
            "value": "taskEnding",
            "label": "phase.taskEnding"
          },
          {
            "value": "postCommit",
            "label": "phase.postCommit"
          }
        ],
        "textResourceBindings": {
          "title": "phase.title"
        }
      },
      {
        "dataModelBindings": {
          "simpleBinding": {
            "field": "delayMs",
            "dataType": "TransitionControl"
          }
        },
        "id": "delayMs",
        "type": "RadioButtons",
        "preselectedOptionIndex": 0,
        "options": [
          {
            "value": "0",
            "label": "delayMs.none"
          },
          {
            "value": "3000",
            "label": "delayMs.short"
          },
          {
            "value": "8000",
            "label": "delayMs.medium"
          },
          {
            "value": "15000",
            "label": "delayMs.long"
          },
          {
            "value": "30000",
            "label": "delayMs.veryLong"
          }
        ],
        "textResourceBindings": {
          "title": "delayMs.title"
        }
      },
      {
        "dataModelBindings": {
          "simpleBinding": {
            "field": "failCount",
            "dataType": "TransitionControl"
          }
        },
        "id": "failCount",
        "type": "RadioButtons",
        "preselectedOptionIndex": 0,
        "options": [
          {
            "value": "0",
            "label": "failCount.none"
          },
          {
            "value": "1",
            "label": "failCount.one"
          },
          {
            "value": "2",
            "label": "failCount.two"
          },
          {
            "value": "4",
            "label": "failCount.four"
          }
        ],
        "textResourceBindings": {
          "title": "failCount.title"
        }
      },
      {
        "dataModelBindings": {
          "simpleBinding": {
            "field": "failKind",
            "dataType": "TransitionControl"
          }
        },
        "id": "failKind",
        "type": "RadioButtons",
        "preselectedOptionIndex": 0,
        "options": [
          {
            "value": "retryable",
            "label": "failKind.retryable"
          },
          {
            "value": "permanent",
            "label": "failKind.permanent"
          }
        ],
        "textResourceBindings": {
          "title": "failKind.title"
        }
      },
      {
        "id": "Task1Hint",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Task1.hint"
        }
      },
      {
        "id": "sendinn",
        "type": "Button",
        "textResourceBindings": {
          "title": "sendinn.title"
        }
      }
    ]
  }
}

{
  "$schema": "https://altinncdn.no/toolkits/altinn-app-frontend/4/schemas/json/layout/layout.schema.v1.json",
  "data": {
    "hidden": false,
    "layout": [
      {
        "size": "L",
        "id": "Task2Header",
        "type": "Header",
        "textResourceBindings": {
          "title": "Task2.header.title"
        }
      },
      {
        "id": "Task2Description",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Task2.description"
        }
      },
      {
        "id": "buttonGroupTask2",
        "type": "ButtonGroup",
        "children": ["backTask2", "sendinnTask2"]
      },
      {
        "id": "backTask2",
        "type": "ActionButton",
        "action": "reject",
        "buttonStyle": "secondary",
        "textResourceBindings": {
          "title": "back.title"
        }
      },
      {
        "id": "sendinnTask2",
        "type": "Button",
        "textResourceBindings": {
          "title": "sendinn.title"
        }
      }
    ]
  }
}

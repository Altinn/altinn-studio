{
  "$schema": "https://altinncdn.no/toolkits/altinn-app-frontend/4/schemas/json/layout/layout.schema.v1.json",
  "data": {
    "hidden": false,
    "layout": [
      {
        "id": "ParagraphPage-NavigationBar",
        "type": "NavigationBar"
      },
      {
        "id": "ParagraphPage-Header",
        "type": "Header",
        "size": "h2",
        "textResourceBindings": {
          "title": "Avsnitt"
        }
      },
      {
        "id": "ParagraphPage-Header-Component",
        "type": "Header",
        "size": "h3",
        "textResourceBindings": {
          "title": "Header.Component"
        }
      },
      {
        "id": "ParagraphPage-Paragraph-Basic",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Dette er et enkelt avsnitt med litt tekst."
        }
      },
      {
        "id": "ParagraphPage-Paragraph-Help",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Dette er et avsnitt med en tilhørende hjelpetekst.",
          "help": "Dette er hjelpeteksten som vises i et verktøytips ved siden av avsnittet."
        }
      },
      {
        "id": "ParagraphPage-Paragraph-Long",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur."
        }
      },
      {
        "id": "ParagraphPage-Paragraph-Markdown",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Dette avsnittet bruker **fet skrift**, *kursiv* og en [lenke](https://altinn.studio)."
        }
      },
      {
        "id": "ParagraphPage-Paragraph-Grid",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Dette avsnittet bruker grid og tar halv bredde på større skjermer."
        },
        "grid": {
          "xs": 12,
          "md": 6
        }
      },
      {
        "type": "Cards",
        "id": "ParagraphPage-Card",
        "color": "subtle",
        "cards": [
          {
            "title": "Avsnitt i et kort",
            "description": "",
            "children": ["ParagraphPage-Paragraph-InCard"]
          }
        ]
      },
      {
        "id": "ParagraphPage-Paragraph-InCard",
        "type": "Paragraph",
        "textResourceBindings": {
          "title": "Dette avsnittet er plassert inne i en Cards-komponent."
        }
      },
      {
        "id": "ParagraphPage-NavigationButtons",
        "type": "NavigationButtons",
        "showBackButton": true,
        "textResourceBindings": {}
      }
    ]
  }
}

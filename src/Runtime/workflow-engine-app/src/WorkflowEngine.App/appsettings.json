{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "WorkflowEngine.Data.Services": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
      "WorkflowEngine": "Host=localhost;Port=5433;Database=workflow_engine;Username=postgres;Password=postgres123"
  },
  "EngineSettings": {
    "Concurrency": {
      "MaxWorkers": 400,
      "MaxDbOperations": 10
    },
    "DefaultStepCommandTimeout": "00:01:40",
    "DefaultStepRetryStrategy": {
      "BackoffType": "exponential",
      "BaseInterval": "00:00:01",
      "MaxDelay": "00:05:00",
      "MaxDuration": "24:00:00",
      "NonRetryableHttpStatusCodes": [400, 401, 403, 404, 422]
    },
    "DatabaseCommandTimeout": "00:00:30",
    "DatabaseRetryStrategy": {
      "BackoffType": "exponential",
      "BaseInterval": "00:00:00.100",
      "MaxDelay": "00:02:00",
      "MaxDuration": "02:00:00"
    }
  },
  "AppCommandSettings": {
    "ApiKey": "afc64bcf-fedf-442d-8d41-09b8c5f03c59",
    "CommandEndpoint":  "http://local.altinn.cloud/{Org}/{App}/instances/{InstanceOwnerPartyId}/{InstanceGuid}/workflow-engine-callbacks"
  }
}

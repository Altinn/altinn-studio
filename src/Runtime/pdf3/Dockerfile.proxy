FROM --platform=$BUILDPLATFORM golang:1.26.5-trixie@sha256:4ee9ffa999b4583ce281939cdff828763083610292f252279a0cee77473bd9a7 AS builder
ARG TARGETOS
ARG TARGETARCH

WORKDIR /app

COPY go.mod go.sum ./

RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -o main ./cmd/proxy

FROM scratch

WORKDIR /app

COPY --from=builder /app/main .

EXPOSE 5030

COPY --from=builder /etc/passwd /etc/passwd
USER nobody

ENTRYPOINT ["./main"]

{
  "name": "studio-designer-frontend",
  "dependencies": {
    "@digdir/design-system-tokens": "0.13.0",
    "@digdir/designsystemet-css": "0.10.0",
    "@digdir/designsystemet-react": "0.63.1",
    "@digdir/designsystemet-theme": "0.15.3",
    "@microsoft/applicationinsights-react-js": "17.3.6",
    "@microsoft/applicationinsights-web": "3.4.3",
    "@microsoft/signalr": "8.0.17",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "date-fns": "4.4.0",
    "i18next": "25.10.10",
    "identity-obj-proxy": "3.0.0",
    "react": "19.2.7",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "react-i18next": "17.0.9",
    "react-router-dom": "7.17.0",
    "react-toastify": "11.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@oddbird/popover-polyfill": "^0.7.0",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/css-modules": "1.0.5",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "css-loader": "7.1.4",
    "eslint": "10.5.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.4.6",
    "eslint-plugin-testing-library": "7.16.2",
    "glob": "11.1.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-fail-on-console": "3.3.4",
    "jest-junit": "16.0.0",
    "lightningcss": "^1.29.3",
    "mini-css-extract-plugin": "2.10.2",
    "prettier": "3.8.5",
    "source-map-loader": "5.0.0",
    "swc-loader": "0.2.7",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "^6.3.2",
    "whatwg-fetch": "3.6.20"
  },
  "resolutions": {
    "@testing-library/dom": "10.4.1",
    "@babel/traverse": "7.29.7",
    "caniuse-lite": "1.0.30001803"
  },
  "packageManager": "yarn@4.16.0",
  "private": true,
  "scripts": {
    "build": "yarn workspaces foreach -A -p --include 'src/Designer/**' run build",
    "lint": "eslint \"**/*.ts*\"",
    "lint:fix": "yarn run lint --fix",
    "codestyle:check": "prettier . --check",
    "codestyle:fix": "prettier . --write",
    "setup": "lefthook install && node development/setup.js && yarn run git:ignore-revs",
    "sort-texts": "yarn workspace @altinn-studio/language run sort",
    "start-app-development": "yarn workspace app-development start",
    "appdev:preview": "yarn workspace app-development preview",
    "appdev:build": "yarn workspace app-development build",
    "start-app-preview": "yarn workspace app-preview start",
    "start-dashboard": "yarn workspace dashboard start",
    "start-resourceadm": "yarn workspace resourceadm start",
    "start-studio-root": "yarn workspace studio-root start",
    "start-admin": "yarn workspace admin start",
    "start-settings": "yarn workspace settings start",
    "stats": "node stats.js",
    "syncpack": "npx syncpack fix-mismatches && npx syncpack format && npx syncpack set-semver-ranges",
    "test": "jest --maxWorkers=50% --config=jest.config.js",
    "test:ci": "jest --ci --coverage --max-workers=2 --cacheDirectory=$(yarn config get cacheFolder) --config=jest.config.js",
    "typecheck": "tsc --noEmit -p .",
    "strict-null-checks": "tsc --noEmit -p tsconfig-strict.json",
    "playwright:test:all": "yarn workspace playwright-studio test:all",
    "playwright:test:ui": "yarn workspace playwright-studio test:ui",
    "resourceadm:playwright:test:ui": "yarn workspace playwright-resourceadm resourceadm:test:ui",
    "resourceadm:playwright:test:all": "yarn workspace playwright-resourceadm resourceadm:test:all",
    "git:ignore-revs": "git config blame.ignoreRevsFile .git-blame-ignore-revs"
  },
  "syncpack": {
    "semverRange": ""
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 8",
    "not op_mini all"
  ]
}

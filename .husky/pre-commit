#!/usr/bin/env sh
yarn lint-staged

(
  STAGED_FILES_DESIGNER_BACKEND=$(git diff --cached --name-only --diff-filter=ACM | grep -e '^src/Designer/backend' | sed 's|^src/Designer/backend/||')

  if [ -n "$STAGED_FILES_DESIGNER_BACKEND" ]; then
    echo "Found staged files in src/Designer/backend, running csharpier..."
    cd src/Designer/backend
    dotnet tool restore
    dotnet csharpier format $STAGED_FILES_DESIGNER_BACKEND
    git add $STAGED_FILES_DESIGNER_BACKEND
  fi
)

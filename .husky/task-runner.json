{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "Run csharpier",
         "command": "dotnet",
         "args": [ "csharpier", "format", "${staged}" ],
         "cwd": "src/Designer/backend",
         "include": [
            "**/*.cs",
            "**/*.csx",
            "**/*.csproj",
            "**/*.props",
            "**/*.targets",
            "**/*.xml",
            "**/*.config"
         ]
      }
   ]
}

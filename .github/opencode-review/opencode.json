{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "azure-openai": {
      "npm": "@ai-sdk/azure",
      "options": {
        "apiKey": "{env:AZURE_OPENAI_API_KEY}",
        "resourceName": "{env:AZURE_OPENAI_RESOURCE}",
        "apiVersion": "2025-04-01-preview"
      },
      "models": {
        "gpt-5.5": {}
      }
    },
    "azure-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "{env:AZURE_ANTHROPIC_API_KEY}",
        "baseURL": "https://{env:AZURE_FOUNDRY_RESOURCE}.services.ai.azure.com/anthropic/v1"
      },
      "models": {
        "claude-sonnet-4-6": {}
      }
    }
  }
}

{
  "compilerOptions": {
    "target": "es2022",
    "module": "preserve",
    "lib": ["es2022"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "paths": {
      "@app/language/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
